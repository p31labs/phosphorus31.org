{
  "name": "@p31labs/game-core",
  "version": "0.1.0",
  "description": "Phase transition — freeze/thaw physics for bonding and mesh. Adopt or replace from Claude's p31-universe when merged.",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "keywords": ["p31", "phase", "freeze", "thaw", "physics", "bonding"],
  "author": "P31 Labs",
  "license": "AGPL-3.0",
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.2.0"
  }
}
