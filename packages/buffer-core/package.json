{
  "name": "@p31labs/buffer-core",
  "version": "0.1.0",
  "description": "The Buffer scoring engine — voltage calculator, spoon tracker, Samson V2 PID controller",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "keywords": ["buffer", "voltage", "scoring", "spoons", "samson", "pid", "p31"],
  "author": "P31 Labs",
  "license": "AGPL-3.0",
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.2.0"
  }
}
