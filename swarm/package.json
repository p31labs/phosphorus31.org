{
  "name": "project-swarm-intelligence",
  "version": "2.0.0",
  "description": "Autonomous swarm system for project management, analysis, organization, and maintenance",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "swarm": "node dist/index.js --swarm-mode",
    "daemon": "node dist/index.js --daemon",
    "scan": "node dist/index.js --scan-only",
    "analyze": "node dist/index.js --analyze-only",
    "organize": "node dist/index.js --organize-only",
    "update": "node dist/index.js --update-only",
    "repair": "node dist/index.js --repair-only",
    "test": "jest",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts",
    "docs": "typedoc src/index.ts --out docs",
    "clean": "rimraf dist",
    "watch": "nodemon --exec npm run build --watch"
  },
  "keywords": [
    "swarm",
    "ai",
    "project-management",
    "autonomous",
    "analysis",
    "organization",
    "maintenance",
    "repair",
    "scaling"
  ],
  "author": "Project Swarm Intelligence Team",
  "license": "AGPL-3.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/project-swarm-intelligence/swarm.git"
  },
  "bugs": {
    "url": "https://github.com/project-swarm-intelligence/swarm/issues"
  },
  "homepage": "https://github.com/project-swarm-intelligence/swarm#readme",
  "dependencies": {
    "@types/node": "^20.0.0",
    "chokidar": "^3.5.3",
    "fs-extra": "^11.1.1",
    "glob": "^10.3.0",
    "globby": "^11.1.0",
    "node-cron": "^3.0.2",
    "openai": "^4.14.0",
    "semver": "^7.5.4",
    "simple-git": "^3.19.1",
    "typescript": "^5.1.6",
    "yaml": "^2.3.1",
    "zod": "^3.22.4",
    "axios": "^1.4.0",
    "lodash": "^4.17.21",
    "minimist": "^1.2.8",
    "ora": "^8.0.1",
    "chalk": "^4.1.2",
    "cli-progress": "^3.12.0",
    "node-schedule": "^2.1.1",
    "tree-kill": "^1.2.2",
    "execa": "^8.0.1",
    "fast-glob": "^3.3.1",
    "ignore": "^5.2.4",
    "natural": "^6.1.3",
    "sentiment": "^6.1.0",
    "node-machine-id": "^1.1.12",
    "os-utils": "^0.0.14",
    "systeminformation": "^5.21.13"
  },
  "devDependencies": {
    "@types/chokidar": "^3.5.4",
    "@types/fs-extra": "^11.0.1",
    "@types/glob": "^8.1.0",
    "@types/minimist": "^1.2.2",
    "@types/node-cron": "^3.0.10",
    "@types/semver": "^7.5.0",
    "@types/simple-git": "^3.15.0",
    "@types/yaml": "^2.0.2",
    "@typescript-eslint/eslint-plugin": "^5.60.1",
    "@typescript-eslint/parser": "^5.60.1",
    "eslint": "^8.44.0",
    "jest": "^29.6.1",
    "nodemon": "^3.0.1",
    "prettier": "^2.8.8",
    "rimraf": "^5.0.1",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.1",
    "typedoc": "^0.25.0",
    "typescript": "^5.1.6"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist/**/*",
    "src/**/*",
    "config/**/*",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "swarm": "dist/index.js"
  }
}