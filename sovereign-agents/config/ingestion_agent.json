{
    "name": "Ingestion Agent (Gatekeeper)",
    "target_directory": "~/Downloads",
    "scan_frequency_seconds": 900,
    "rules": {
        "categorize": [
            {"pattern": "*.{jpg,png,gif}", "category": "images"},
            {"pattern": "*.{pdf,docx,txt}", "category": "documents"},
            {"pattern": "*.zip", "category": "archives"},
            {"pattern": "project_*.zip", "category": "project_archives"}
        ],
        "scrub": {
            "enabled": false,
            "mode": "report_only"
        },
        "rename": {
            "enabled": true,
            "format": "{date}_{category}_{original_name}"
        },
        "move": {
            "enabled": true,
            "target_base": "~/Documents/Sorted"
        }
    }
}