# ═══════════════════════════════════════════════════════════════════════════════
# P31 LABS — Environment Configuration
# Copy to .env and fill in your values. All vars are optional.
# The site works fully offline without any of these set.
# ═══════════════════════════════════════════════════════════════════════════════

# ── AI Provider (pick ONE — powers the molecule formation conversation) ──────
# Get a key from: aistudio.google.com (Gemini), platform.openai.com, console.anthropic.com
VITE_GEMINI_KEY=
# VITE_OPENAI_KEY=
# VITE_ANTHROPIC_KEY=

# ── Shelter Backend (optional — enables sync, offline-first without it) ──────
# VITE_SHELTER_URL=https://your-shelter.fly.dev
# VITE_SHELTER_KEY=

# ── Colyseus Multiplayer (optional — WorldBuilder sync) ──────────────────────
# VITE_COLYSEUS_URL=ws://localhost:2567

# ── Mesh WebSocket (optional — real-time mesh status) ────────────────────────
# VITE_MESH_WS_URL=ws://localhost:4001

# ── Buffer Service (optional — communication voltage processing) ─────────────
# VITE_BUFFER_URL=http://localhost:4000
# VITE_BUFFER_WS_URL=ws://localhost:4000

# ── Centaur Backend (optional — AI backend services) ─────────────────────────
# VITE_CENTAUR_API_URL=http://localhost:3000
