    "@tensorflow/tfjs": "^4.21.0",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.16",
    "colyseus.js": "^0.16.0",
    "eventemitter3": "^5.0.1",
    "gsap": "^3.14.2",
    "leva": "^0.10.1",
    "lucide-react": "^0.344.0",
    "postcss": "^8.4.32",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.28.0",
    "tailwindcss": "^3.4.0",
    "three": "^0.169.0",
    "tone": "^15.0.4",
    "vite": "^5.0.8",
    "zustand": "^4.5.0"
