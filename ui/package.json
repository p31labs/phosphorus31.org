{
  "name": "@p31labs/scope",
  "version": "0.1.0",
  "type": "module",
  "description": "The Scope — Dashboard and visualization layer for P31 ecosystem",
  "author": "P31 Labs",
  "license": "AGPL-3.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/p31labs/p31.git",
    "directory": "ui"
  },
  "homepage": "https://phosphorus31.org",
  "main": "src/main.tsx",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "typecheck": "tsc -p tsconfig.build.json",
    "build:strict": "tsc -p tsconfig.build.json && vite build",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
