# AI Provider — set ONE of these (first found wins). Or paste a key at runtime in the app.
# VITE_ANTHROPIC_KEY=sk-ant-...
# VITE_OPENAI_KEY=sk-...
# VITE_GEMINI_KEY=AIzaSyBPP4v08KXkrkktno5NTssx9idxP5FSWKQ

# P31 Quantum Geodesic Platform — Colyseus server URL
# Optional: only needed for multiplayer World Builder sync
VITE_COLYSEUS_URL=ws://localhost:2567

# P31 Shelter (Buffer) — message processing; Scope Tasks/Health and game client use this
# Optional: defaults to http://localhost:4000 if unset. Set if Shelter uses fallback port (e.g. 4001).
# Either name works: VITE_SHELTER_URL or VITE_BUFFER_URL (VITE_SHELTER_URL preferred).
VITE_SHELTER_URL=http://localhost:4000

# Mesh / NODE ONE — when hardware or bridge is on board, Scope sends Sprout signals here
# Optional: set to Buffer WebSocket (e.g. ws://localhost:4000/ws) or mesh bridge URL
# When set, Sprout "I need a break" / "I need help" go over WS instead of simulator
# VITE_MESH_WS_URL=ws://localhost:4000/ws

# Optional Shelter API key for molecule registration / game integration (leave empty for local dev)
# VITE_SHELTER_KEY=
