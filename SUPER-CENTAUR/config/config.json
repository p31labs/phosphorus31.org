{
  "server": {
    "port": 3001,
    "host": "localhost",
    "cors": {
      "origin": [
        "http://localhost:3000",
        "http://localhost:5173"
      ],
      "credentials": true
    },
    "rateLimit": {
      "windowMs": 900000,
      "max": 100
    }
  },
  "database": {
    "type": "sqlite",
    "database": "super-centaur.db",
    "vectorStore": true
  },
  "ai": {
    "provider": "openai",
    "model": "gpt-4",
    "temperature": 0.7,
    "maxTokens": 4000
  },
  "blockchain": {
    "provider": "http://localhost:8545",
    "network": "local",
    "contracts": {
      "legalFramework": "",
      "identity": "",
      "governance": ""
    },
    "wallet": {}
  },
  "legal": {
    "jurisdiction": "US",
    "courtSystem": "federal",
    "documentTemplates": [
      "emergency-motion",
      "legal-response",
      "compliance-check"
    ],
    "emergencyProtocols": true
  },
  "medical": {
    "enableDocumentation": true,
    "conditions": [
      "hypoparathyroidism",
      "intellectual-gaps",
      "generational-trauma"
    ],
    "expertWitness": true,
    "compliance": {
      "HIPAA": true,
      "GDPR": true
    }
  },
  "security": {
    "encryption": {
      "algorithm": "aes-256-gcm",
      "keySize": 256
    },
    "authentication": {
      "jwtSecret": "super-centaur-secret-key",
      "expiresIn": "24h"
    },
    "audit": {
      "enabled": true,
      "retentionDays": 365
    }
  },
  "frontend": {
    "port": 3000,
    "buildDir": "dist",
    "publicDir": "public"
  },
  "cli": {
    "theme": {
      "primary": "#6366f1",
      "secondary": "#8b5cf6",
      "success": "#10b981",
      "warning": "#f59e0b",
      "error": "#ef4444"
    },
    "spinner": "dots"
  }
}