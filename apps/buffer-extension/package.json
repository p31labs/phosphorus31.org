{
  "name": "@p31labs/buffer-extension",
  "version": "0.1.0",
  "private": true,
  "description": "The Buffer — Chrome extension for Gmail/Slack voltage-gated messaging",
  "type": "module",
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build && node -e \"const fs=require('fs');fs.copyFileSync('manifest.json','dist/manifest.json');fs.cpSync('icons','dist/icons',{recursive:true})\"",
    "typecheck": "tsc --noEmit"
  },
  "author": "P31 Labs",
  "license": "AGPL-3.0",
  "dependencies": {
    "@p31labs/buffer-core": "workspace:*",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.303",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "typescript": "^5.4.0",
    "vite": "^6.0.0"
  }
}
