{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "emitDeclarationOnly": false,
    "allowImportingTsExtensions": false,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "jsx": "preserve",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "node"
  },
  "include": [
    "src/index.ts",
    "src/server.ts",
    "src/queue.ts",
    "src/store.ts",
    "src/utils/logger.ts",
    "src/ping.ts",
    "src/filter.ts",
    "src/retry.ts",
    "src/monitoring.ts",
    "src/centaur-client.ts",
    "src/metabolism.ts",
    "src/security/security-middleware.ts",
    "src/types.ts"
  ],
  "exclude": ["node_modules", "dist", "**/*.test.ts", "**/*.spec.ts"]
}
