# P31 Shelter — backend only
PORT=4000
NODE_ENV=development
LOG_LEVEL=info

# Optional: Redis (falls back to in-memory if not set)
# REDIS_URL=redis://localhost:6379

# Optional: SQLite paths (Buffer: ./buffer.db, Game: ./game.db)
# DATABASE_URL=sqlite:./buffer.db
# GAME_DATABASE_URL=sqlite:./game.db

# Optional: Accommodation log DB directory (default: ./data)
# ACCOMMODATION_DB_DIR=./data

# Optional: Centaur API (message forwarding)
# CENTAUR_API_URL=http://localhost:3000
# CENTAUR_API_KEY=

# CORS (comma-separated). No wildcard. Production: set to your frontend origins.
# Development default: http://localhost:5173,5174,5175,3000
# Production example: https://phosphorus31.org,https://sprout.p31.io,https://scope.p31.io
# CORS_ORIGIN=http://localhost:5174,http://localhost:5175
